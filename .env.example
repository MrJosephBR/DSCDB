# Docker Compose app container uses db as the PostgreSQL hostname.
DATABASE_URL="postgresql://voc_user:voc_password@db:5432/vocs_db"

APP_ENV="production"
APP_URL="http://localhost:3000"
APP_DOMAIN="localhost"

JWT_SECRET="change_this_secret"
UPLOAD_DIR="/app/uploads"
MAX_UPLOAD_SIZE_MB=50
BACKUP_DIR="/backups"
BACKUP_RETENTION_DAYS=14

POSTGRES_USER="voc_user"
POSTGRES_PASSWORD="voc_password"
POSTGRES_DB="vocs_db"
